s/2817655529"},"html":{"href":"https://github.com/BloopAI/vibe-kanban/pull/2487#discussion_r2817655529"},"pull_request":{"href":"https://api.github.com/repos/BloopAI/vibe-kanban/pulls/2487"}},"reactions":{"url":"https://api.github.com/repos/BloopAI/vibe-kanban/pulls/comments/2817655529/reactions","total_count":0,"+1":0,"-1":0,"laugh":0,"hooray":0,"confused":0,"heart":0,"rocket":0,"eyes":0},"start_line":null,"original_start_line":null,"start_side":null,"line":36,"original_line":36,"side":"RIGHT","author_association":"CONTRIBUTOR","original_position":36,"position":36,"subject_type":"line"},{"url":"https://api.github.com/repos/BloopAI/vibe-kanban/pulls/comments/2816567114","pull_request_review_id":3813466828,"id":2816567114,"node_id":"PRRC_kwDOO7s21M6n4WdK","diff_hunk":"@@ -55,8 +59,19 @@ export function SharedAppLayout() {\n   const { data: orgProjects = [], isLoading } = useOrganizationProjects(\n     selectedOrgId || null\n   );\n+  const sortedProjects = useMemo(\n+    () => sortProjectsByOrder(orgProjects),\n+    [orgProjects]\n+  );\n+  const [orderedProjects, setOrderedProjects] =\n+    useState<RemoteProject[]>(sortedProjects);\n+  const [isSavingProjectOrder, setIsSavingProjectOrder] = useState(false);\n+\n+  useEffect(() => {\n+    setOrderedProjects(sortedProjects);","path":"frontend/src/components/ui-new/containers/SharedAppLayout.tsx","commit_id":"d2ba8c9b7652ec1f356a85c0904c7f023508bba5","original_commit_id":"c35562fa58e9a73a37e28c7857efbc4a12de04da","user":{"login":"abcpro1","id":108011288,"node_id":"U_kgDOBnAfGA","avatar_url":"https://avatars.githubusercontent.com/u/108011288?v=4","gravatar_id":"","url":"https://api.github.com/users/abcpro1","html_url":"https://github.com/abcpro1","followers_url":"https://api.github.com/users/abcpro1/followers","following_url":"https://api.github.com/users/abcpro1/following{/other_user}","gists_url":"https://api.github.com/users/abcpro1/gists{/gist_id}","starred_url":"https://api.github.com/users/abcpro1/starred{/owner}{/repo}","subscriptions_url":"https://api.github.com/users/abcpro1/subscriptions","organizations_url":"https://api.github.com/users/abcpro1/orgs","repos_url":"https://api.github.com/users/abcpro1/repos","events_url":"https://api.github.com/users/abcpro1/events{/privacy}","received_events_url":"https://api.github.com/users/abcpro1/received_events","type":"User","user_view_type":"public","site_admin":false},"body":"**My Recommendation:**\nPre-existing bulk updates (`KanbanContainer`, `RemoteProjectsSettingsSection`) work around this with a `setTimeout` delay. We should instead use `txid` returned by the backend from the bulk endpoint with the Electric collection layer in `frontend/src/lib/electric/collections.ts` which already has txid-based sync tracking via `buildMutationHandlers`. I recommend wiring the bulk project update through Electric's collection mutation system (using `PROJECTS_SHAPE` + `PROJECT_MUTATION`) so the optimistic state is properly held until Electric confirms it has replicated past the write transaction, rather than adding another brittle timeout.\n\n[Tanstack DB recommends using PostgreSQL `txid` to prevent UI glitches](https://tanstack.com/db/latest/docs/collections/electric-collection#persistence-handlers--synchronization)\n","created_at":"2026-02-17T11:33:36Z","updated_at":"2026-02-17T11:34:05Z","html_url":"https://github.com/BloopAI/vibe-kanban/pull/2774#discussion_r2816567114","pull_request_url":"https://api.github.com/repos/BloopAI/vibe-kanban/pulls/2774","_links":{"self":{"href":"https://api.github.com/repos/BloopAI/vibe-kanban/pulls/comments/2816567114"},"html":{"href":"https://github.com/BloopAI/vibe-kanban/pull/2774#discussion_r2816567114"},"pull_request":{"href":"https://api.github.com/repos/BloopAI/vibe-kanban/pulls/2774"}},"reactions":{"url":"https://api.github.com/repos/BloopAI/vibe-kanban/pulls/comments/2816567114/reactions","total_count":0,"+1":0,"-1":0,"laugh":0,"hooray":0,"confused":0,"heart":0,"rocket":0,"eyes":0},"start_line":