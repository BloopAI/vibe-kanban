setOrderedProjects(previousOrder);\n+      } finally {\n+        window.setTimeout(() => {\n+          isSyncingProjectOrderRef.current = false;\n+          setIsSavingProjectOrder(false);\n+        }, 500);","path":"frontend/src/components/ui-new/containers/SharedAppLayout.tsx","commit_id":"0333f13b8eb6413af5b650b46b945d2de6daee7c","original_commit_id":"0333f13b8eb6413af5b650b46b945d2de6daee7c","user":{"login":"abcpro1","id":108011288,"node_id":"U_kgDOBnAfGA","avatar_url":"https://avatars.githubusercontent.com/u/108011288?v=4","gravatar_id":"","url":"https://api.github.com/users/abcpro1","html_url":"https://github.com/abcpro1","followers_url":"https://api.github.com/users/abcpro1/followers","following_url":"https://api.github.com/users/abcpro1/following{/other_user}","gists_url":"https://api.github.com/users/abcpro1/gists{/gist_id}","starred_url":"https://api.github.com/users/abcpro1/starred{/owner}{/repo}","subscriptions_url":"https://api.github.com/users/abcpro1/subscriptions","organizations_url":"https://api.github.com/users/abcpro1/orgs","repos_url":"https://api.github.com/users/abcpro1/repos","events_url":"https://api.github.com/users/abcpro1/events{/privacy}","received_events_url":"https://api.github.com/users/abcpro1/received_events","type":"User","user_view_type":"public","site_admin":false},"body":"Pre-existing bulk updates (KanbanContainer, RemoteProjectsSettingsSection) work around this with a setTimeout delay. We should instead use txid returned by the backend from the bulk endpoint with the Electric collection layer in frontend/src/lib/electric/collections.ts which already has txid-based sync tracking via buildMutationHandlers. I recommend wiring the bulk project update through Electric's collection mutation system (using PROJECTS_SHAPE + PROJECT_MUTATION) so the optimistic state is properly held until Electric confirms it has replicated past the write transaction, rather than adding another brittle timeout.\n\nTanstack DB recommends using PostgreSQL t