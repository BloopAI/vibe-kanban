vadyms-macbook-pro.tail3de41b.ts.net:3001 {
    tls vadyms-macbook-pro.tail3de41b.ts.net.crt vadyms-macbook-pro.tail3de41b.ts.net.key
    handle /api/* {
        reverse_proxy 127.0.0.1:3000
    }
